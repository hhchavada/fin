	"item": [
		{
			"name": "🔥 1. Trending Stocks",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test(\"Response has success field\", function () {",
							"    const jsonData = pm.response.json();",
							"    pm.expect(jsonData.success).to.be.true;",
							"});",
							"",
							"pm.test(\"Data stored in trending_stocks collection\", function () {",
							"    const jsonData = pm.response.json();",
							"    pm.expect(jsonData.data.api_name).to.eql(\"trending\");",
							"    pm.expect(jsonData.data.status).to.be.oneOf([\"success\", \"failed\"]);",
							"});",
							"",
							"// Log response time for monitoring",
							"if (pm.response.json().data && pm.response.json().data.response_time_ms) {",
							"    console.log(\"Response Time:\", pm.response.json().data.response_time_ms + \"ms\");",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "http://localhost:3000/api/v1/multi-stock/fetch/trending",
					"protocol": "http",
					"host": ["localhost"],
					"port": "3000",
					"path": ["api", "v1", "multi-stock", "fetch", "trending"]
				},
				"description": "Fetches trending stocks data and stores in 'trending_stocks' collection"
			},
			"response": []
		},
