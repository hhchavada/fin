	"item": [
		{
			"name": "🔥 1. Trending Stocks",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test(\"Response has success field\", function () {",
							"    const jsonData = pm.response.json();",
							"    pm.expect(jsonData.success).to.be.true;",
							"});",
							"",
							"pm.test(\"Data retrieved from database\", function () {",
							"    const jsonData = pm.response.json();",
							"    pm.expect(jsonData.data).to.not.be.null;",
							"    pm.expect(jsonData.data).to.have.property('top_gainers');",
							"});",
							"",
							"// Log response time for monitoring",
							"if (pm.response.json().response_time_ms) {",
							"    console.log(\"Database Response Time:\", pm.response.json().response_time_ms + \"ms\");",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "http://localhost:3000/api/v1/stock-data/trending",
					"protocol": "http",
					"host": ["localhost"],
					"port": "3000",
					"path": ["api", "v1", "stock-data", "trending"]
				},
				"description": "Retrieves trending stocks data from database collection"
			},
			"response": []
		},
