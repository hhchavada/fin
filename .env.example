
# Server Configuration
PORT=3000
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/fin-db
MONGODB_TEST_URI=mongodb://localhost:27017/fin-db-test

# JWT Configuration (for future use)
JWT_SECRET=your-super-secret-jwt-key
JWT_EXPIRES_IN=7d

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# RapidAPI Configuration
RAPIDAPI_HOST=indian-stock-exchange-api2.p.rapidapi.com
RAPIDAPI_KEY=your-rapidapi-key-here

# Stock API Configuration
STOCK_API_BASE_URL=https://indian-stock-exchange-api2.p.rapidapi.com

# Cron Configuration
CRON_ENABLED=false
CRON_SCHEDULE=*/3 * * * *

# API Configuration
API_TIMEOUT=30000
API_MAX_RETRIES=3
API_RETRY_DELAY=1000

# Logging Configuration
LOG_LEVEL=info
